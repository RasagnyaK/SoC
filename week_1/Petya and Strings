#include <string>
#include <iostream>
#include <cctype>
using namespace std;
int main(){
    string s1;
    string s2;
    cin >> s1;
    cin >> s2;
    int a;
    a=s1.length();
    for(int i=0;i<a;i++){
        char x = tolower(s1[i]);
        char y = tolower(s2[i]);
        if(x > y){
            cout << "1";
            return 0;
        }
        if(x < y){
            cout << "-1";
            return 0;
        }
    }
    cout << "0";
    return 0;
}
