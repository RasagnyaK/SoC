#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;
int ones( int i , int j , vector<int> v){
    int count=0;
    for(int a=i;a<=j;a++){
        if(v[a] == 0){
            count +=1;
        }
        else{
            count = count-1;
        }
    }
    return count;
}
int main(){
    int n;
    cin >> n;
    int total = 0;
    vector<int> a(n);
    for(int i=0;i<n;i++){
        cin >> a[i];
        if(a[i] == 1){
            total += 1;
        }
    }
     int maxi = -1e9;
    for(int x=0;x<n;x++){
        for(int y=x;y<n;y++){
            maxi = max(maxi,ones(x,y,a));
        }
    }
    cout << maxi+total;
    return 0;
}
