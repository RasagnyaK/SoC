#include <iostream>
#include <string>
#include <cctype>
using namespace std;
int main(){
    string s,t;
    cin >> s >>t;
    string a;
    int x = s.length();
    for(int i=0;i<x;i++){
        a += s[x-1-i];
    }
    if(a == t){
        cout << "YES";
        return 0;
    }
    else{
        cout << "NO";
        return 0;
    }
}
