#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;
int abs(int x,int y){
    if(x-y>0){
        return x-y;
    }
    else{
        return y-x;
    }
}
int main(){
    int n;
    cin >> n;
    vector<int> a(n);
    for(int i=0;i<n;i++){
        cin >> a[i];
        vector<int> b(2*a[i]);
        for(int j=0;j<2*a[i];j++){
            cin >> b[j];
        }
        sort(b.begin(),b.end());
        vector<int> c(a[i]);
        vector<int> d(a[i]);
        for(int x=0;x<a[i];x++){
            c[x] = b[x];
        }
        for(int x=0;x<a[i];x++){
            d[x] = b[x+a[i]];
        }
        int r=0;
        int s=0;
        for(int p=0;p<a[i]-1;p++){
            r += abs(c[p],c[p+1]);
        }
        for(int q=0;q<a[i]-1;q++){
            s += abs(d[q],d[q+1]);
        }
        cout << r+s << "\n";
        for(int t=0;t<a[i];t++){
            cout << c[t] << " " << d[t] << "\n";
        }
    }

}
