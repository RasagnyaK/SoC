#include <iostream>
#include <vector>
#include <string>
#include <queue>
using namespace std;

int main() {
    long long t;
    cin >> t;

    while (t--) {
        long long n;
        cin >> n;

        vector<vector<char>> grid(2, vector<char>(n));

        for (long long p = 0; p < n; p++) {
            cin >> grid[0][p];
        }
        for (long long p = 0; p < n; p++) {
            cin >> grid[1][p];
        }

        vector<vector<int>> vis(2, vector<int>(n, 0));
        queue<pair<int,int>> q;

        q.push({0, 0});
        vis[0][0] = 1;

        bool ok = false;

        while (!q.empty()) {
            auto cur = q.front();
            q.pop();

            int r = cur.first;
            int c = cur.second;

            if (r == 1 && c == n - 1) {
                ok = true;
                break;
            }

            int dr[4] = {0, 0, 1, -1};
            int dc[4] = {1, -1, 0, 0};

            for (int i = 0; i < 4; i++) {
                int nr = r + dr[i];
                int nc = c + dc[i];

                if (nr < 0 || nr > 1 || nc < 0 || nc >= n) continue;

                // apply arrow after moving
                if (grid[nr][nc] == '>') nc++;
                else nc--;

                if (nc < 0 || nc >= n) continue;

                if (!vis[nr][nc]) {
                    vis[nr][nc] = 1;
                    q.push({nr, nc});
                }
            }
        }

        if (ok) cout << "YES\n";
        else cout << "NO\n";
    }

    return 0;
}
