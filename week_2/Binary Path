#include <iostream>
#include <string>
using namespace std;

int main() {
    int t;
    cin >> t;

    while (t--) {
        int n;
        cin >> n;

        string a, b;
        cin >> a >> b;

        int pos = n - 1;

        for (int i = 0; i < n - 1; i++) {
            if (b[i] < a[i + 1]) {
                pos = i;
                break;
            }
            if (b[i] > a[i + 1]) {
                continue;
            }
        }

        string ans = "";

        for (int i = 0; i <= pos; i++) {
            ans += a[i];
        }

        for (int i = pos; i < n; i++) {
            ans += b[i];
        }

        long long cnt = 1;

        int j = pos;
        while (j > 0 && a[j] == b[j - 1]) {
            cnt++;
            j--;
        }

        cout << ans << "\n";
        cout << cnt << "\n";
    }

    return 0;
}
