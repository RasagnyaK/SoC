#include <iostream>
#include <vector>
#include <string>
using namespace std;
int main(){
    long long t;
    cin >> t;
    vector<long long> a(t);
    vector<string> s(t,"YES");
    for(long long i=0;i<t;i++){
        cin >> a[i];
        vector<long long> b(a[i]);
        for(long long j=0;j<a[i];j++){
            cin >> b[j];
        }
        long long count=0;
        for(long long j=0;j<a[i];j++){
            if(j%2!=0){
                count-=b[j];
            }
            else{
                count=count+b[j];
            }
        }
        if(a[i]%2==0){
            if(count<=0){
                s[i] = "YES";
            }
            else{
                s[i] = "NO";
            } 
        }
        if(a[i]%2!=0){
            s[i] = "YES";
        }
        cout << s[i] << "\n";
    }
}
