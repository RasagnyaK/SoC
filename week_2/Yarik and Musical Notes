#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;
int main(){
    long long t;
    cin >> t;
    vector<long long> a(t);
    vector<long long> count(t,0);
    for(long long i=0;i<t;i++){
        cin >> a[i];
        vector<long long> b(a[i]);
        for(long long j=0;j<a[i];j++){
            cin >> b[j];
        }
        sort(b.begin(),b.end());
        long long x=b[0];
        long long y=0;
        long long z=0;
        long long c = 0;
        for(long long j=0;j<a[i];j++){
            if(x == b[j]){
            c += 1;    
            }
            else{
                count[i] += (c*(c-1))/2;
                c = 1;
                x = b[j];
            }
            if(b[j] == 1){
                y += 1;
            }
            if(b[j] == 2){
                z +=1;
            }
        }
        count[i] = count[i]+(y*z)+((c*(c-1))/2);
        cout << count[i] << "\n";
    }
}
