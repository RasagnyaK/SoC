#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

int main(){
    long long n, d;
    cin >> n >> d;

    vector<long long> a(n);

    for (long long i = 0; i < n; i++) {
        cin >> a[i];
    }

    sort(a.rbegin(), a.rend());

    long long i = 0;
    long long j = n - 1;
    long long ans = 0;

    while (i <= j) {
        long long mx = a[i];
        long long need = d / mx + 1;

        long long cnt = 0;

        // take strongest first
        i++;
        cnt = 1;

        // take weakest to fill team
        while (i <= j && cnt < need) {
            j--;
            cnt++;
        }

        if (cnt >= need) {
            ans++;
        } else {
            break;
        }
    }

    cout << ans << "\n";

    return 0;
}
