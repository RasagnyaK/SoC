#include <iostream>
#include <string>
#include <vector>
using namespace std;
int main(){
    long long n;
    cin >> n;
    vector<long long> a(n);
    for(long long i=0;i<n;i++){
        cin >> a[i];
    }
    vector<long long> b(n);
    for(long long i=0;i<n;i++){
        b[i] = 2*a[i];
    }
    vector<long long> c;
    long long count=1;
    long long ans=1;
    for(long long j=1;j<n;j++){
        if(a[j]<=2*a[j-1]){
            count+=1;
        }
        else{ 
            count=1;
        }
        ans = max(ans,count);
    }
    cout << ans << "\n";
}
