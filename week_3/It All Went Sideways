#include <bits/stdc++.h>
using namespace std;

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    while (t--) {
        int n;
        cin >> n;
        vector<int> a(n);
        for (int i = 0; i < n; i++) cin >> a[i];

        vector<int> smin(n);
        smin[n-1] = a[n-1];
        for (int i = n-2; i >= 0; i--) smin[i] = min(a[i], smin[i+1]);

        long long total = 0, fixed = 0;
        for (int i = 0; i < n; i++) { total += a[i]; fixed += smin[i]; }
        long long base = total - fixed;

        long long best_gain = 0;
        int plateau_start = 0;
        for (int k = 0; k < n; k++) {
            if (k > 0 && smin[k] > smin[k-1]) plateau_start = k;
            if (a[k] == smin[k]) best_gain = max(best_gain, (long long)(k - plateau_start));
        }

        cout << base + best_gain << "\n";
    }
}
