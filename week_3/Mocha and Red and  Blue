#include <iostream>
#include <string>
using namespace std;

int main() {
    int t;
    cin >> t;

    while(t--) {
        int n;
        cin >> n;

        string s;
        cin >> s;

        int pos = -1;

        for(int i = 0; i < n; i++) {
            if(s[i] != '?') {
                pos = i;
                break;
            }
        }

        if(pos == -1) {
            s[0] = 'B';

            for(int i = 1; i < n; i++) {
                if(s[i - 1] == 'B') {
                    s[i] = 'R';
                }
                else {
                    s[i] = 'B';
                }
            }

            cout << s << "\n";
            continue;
        }

        for(int i = pos - 1; i >= 0; i--) {
            if(s[i + 1] == 'B') {
                s[i] = 'R';
            }
            else {
                s[i] = 'B';
            }
        }

        for(int i = pos + 1; i < n; i++) {
            if(s[i] == '?') {
                if(s[i - 1] == 'B') {
                    s[i] = 'R';
                }
                else {
                    s[i] = 'B';
                }
            }
        }

        cout << s << "\n";
    }
}
