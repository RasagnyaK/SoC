#include <iostream>
#include <string>
using namespace std;

int main() {
    long long t;
    cin >> t;

    while(t--) {
        long long n;
        cin >> n;

        string s;
        cin >> s;

        long long ans = 0;

        long long first = -1;

        for(long long i = 0; i < n; i++) {
            if(s[i] == '1') {
                first = i;
                break;
            }
        }

        if(first != -1) {
            for(long long i = first + 1; i < n; i++) {
                if(s[i] != s[i - 1]) {
                    ans++;
                }
            }
        }

        cout << ans << "\n";
    }

    return 0;
}
