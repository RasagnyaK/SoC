#include <iostream>
#include <algorithm>
#include <vector>
#include <cctype>
using namespace std;
int main(){
    long long n;
    cin >> n;
    vector<long long> v;
    long long i=1;
    while(n > 0){
        if(n - i > i){
            v.push_back(i);
            n -= i;
            i++;
        }
        else{
            v.push_back(n);
            break;
        }
    }
    cout << v.size() << "\n";
    for(int x : v){
    cout << x << " ";
    }
    cout << "\n";
}
