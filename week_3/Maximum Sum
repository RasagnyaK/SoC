#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

int main(){
    long long t;
    cin >> t;

    const long long MOD = 1000000007;

    while(t--){
        long long n, k;
        cin >> n >> k;

        vector<long long> b(n);

        long long sum = 0;

        for(long long i = 0; i < n; i++){
            cin >> b[i];
            sum += b[i];
        }
        long long cur = 0;
        long long mx = 0;
        for(long long i = 0; i < n; i++){
            cur = max(0LL, cur + b[i]);
            mx = max(mx, cur);
        }

        long long ans = ((sum % MOD) + MOD) % MOD;

        for(long long i = 0; i < k; i++){
            ans = (ans + mx) % MOD;
            mx = (mx * 2) % MOD;
        }

        cout << ans << "\n";
    }
}
