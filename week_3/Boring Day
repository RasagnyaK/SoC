#include <iostream>
#include <vector>
using namespace std;

int main() {
    int t;
    cin >> t;

    while (t--) {
        int n;
        long long l, r;
        cin >> n >> l >> r;

        vector<long long> a(n);
        for (int i = 0; i < n; i++) cin >> a[i];

        long long sum = 0;
        int ans = 0;
        int i = 0;

        for (int j = 0; j < n; j++) {
            sum += a[j];
            while (sum > r && i <= j) {
                sum -= a[i];
                i++;
            }
            if (sum >= l && sum <= r) {
                ans++;
                sum = 0;
                i = j + 1;
            }
        }

        cout << ans << "\n";
    }

    return 0;
}
