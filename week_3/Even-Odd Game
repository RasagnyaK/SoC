#include <iostream>
#include <vector>
#include <string>
#include <algorithm>
#include <cctype>
using namespace std;
int main(){
    long long t;
    cin >> t;
    vector<long long> a(t);
    for(long long i=0;i<t;i++){
        cin >> a[i];
        vector<long long> b(a[i]);
        for(long long j=0;j<a[i];j++){
            cin >> b[j];
        }
        vector<long long> c;
        vector<long long> d;
        for(long long j=0;j<a[i];j++){
            if(b[j]%2==0){
                c.push_back(b[j]);
            }
            else{
                d.push_back(b[j]);
            }
        }
        long long turn=1;
        long long alice=0;
        long long bob=0;
        sort(b.begin(), b.end(), greater<long long>());
        for(long long j=0;j<a[i];j++){
            if(turn==1){
                if(b[j]%2==0){
                    alice += b[j];
                    turn = -1;
                }
                else{
                    turn = -1;
                }
            }
            else{
                if(b[j]%2==0){
                    turn = 1;
                }
                else{
                    bob += b[j];
                    turn = 1;
                }
            }
        }
        if(alice>bob){ 
            cout << "Alice" << "\n";
        }
        if(bob>alice){
             cout << "Bob" << "\n";
        } 
        if(bob==alice){
             cout << "Tie" << "\n";
        }
    }
}
