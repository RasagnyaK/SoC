#include <iostream>
#include <vector>
#include <algorithm>
#include <cctype>
using namespace std;
int main(){
    long long a1;
    long long a2;
    cin >> a1 >> a2;
    long long time = 0;
    while(a1 > 0 && a2 > 0){
        if(a1 == 1 && a2 == 1){
            break;
        }

        if(a1 < a2){
            a1++;
            a2 -= 2;
        }
        else{
            a2++;
            a1 -= 2;
        }

        if(a1 < 0 || a2 < 0){
            break;
        }

        time++;
    }
    cout << time << "\n";
}
