#include <iostream>
#include <vector>
#include <Algorithm>
using namespace std;
int main(){
    long long t;
    cin >> t;
    vector<long long> a(t);
    for(long long i=0;i<t;i++){
        cin >> a[i];
        vector<long long> b(a[i]);
        for(long long j=0;j<a[i];j++){
            cin >> b[j];
        }
        long long count=0;
        long long k=0;
        while(k<a[i]-1){
            if(b[k]>b[k+1]){
                count += 1;
                k += 2;
            }
            else{
                k += 1;
            }
        }
        cout << count << "\n";
    }
}
