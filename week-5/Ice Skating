#include <bits/stdc++.h>
using namespace std;

void dfs(int node, vector<vector<int>> &adj, vector<int> &vis)
{
    vis[node] = 1;

    for (int next : adj[node])
    {
        if (!vis[next])
        {
            dfs(next, adj, vis);
        }
    }
}

int main()
{
    int n;
    cin >> n;

    vector<pair<int, int>> points(n);

    for (int i = 0; i < n; i++)
    {
        cin >> points[i].first >> points[i].second;
    }

    vector<vector<int>> adj(n);

    for (int i = 0; i < n; i++)
    {
        for (int j = i + 1; j < n; j++)
        {
            if (points[i].first == points[j].first ||
                points[i].second == points[j].second)
            {
                adj[i].push_back(j);
                adj[j].push_back(i);
            }
        }
    }

    vector<int> vis(n, 0);

    int components = 0;

    for (int i = 0; i < n; i++)
    {
        if (!vis[i])
        {
            components++;
            dfs(i, adj, vis);
        }
    }

    cout << components - 1 << '\n';

    return 0;
}
