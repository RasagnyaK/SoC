#include <bits/stdc++.h>
using namespace std;

int main() {
    int t;
    cin >> t;

    while (t--) {
        int n, m;
        cin >> n >> m;

        vector<int> bad(n + 1, 0);

        for (int i = 0; i < m; i++) {
            int a, b, c;
            cin >> a >> b >> c;
            bad[b] = 1;
        }

        int root = -1;

        for (int i = 1; i <= n; i++) {
            if (!bad[i]) {
                root = i;
                break;
            }
        }

        for (int i = 1; i <= n; i++) {
            if (i != root) {
                cout << root << " " << i << '\n';
            }
        }
    }

    return 0;
}
