#include <iostream>
#include <vector>
using namespace std;

int main() {
    int n;
    cin >> n;

    vector<vector<int>> children(n + 1);

    for (int i = 2; i <= n; i++) {
        int p;
        cin >> p;
        children[p].push_back(i);
    }

    bool ok = true;

    for (int i = 1; i <= n; i++) {

        if (children[i].size() == 0) {
            continue;
        }

        int leaf_children = 0;

        for (int child : children[i]) {
            if (children[child].size() == 0) {
                leaf_children++;
            }
        }

        if (leaf_children < 3) {
            ok = false;
            break;
        }
    }

    if (ok) {
        cout << "Yes";
    } else {
        cout << "No";
    }

    return 0;
}
