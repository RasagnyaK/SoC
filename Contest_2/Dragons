#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

int main()
{
    long long s, n;
    cin >> s >> n;

    vector<pair<long long,long long>> dragons(n);

    for(long long i = 0; i < n; i++)
    {
        cin >> dragons[i].first >> dragons[i].second;
    }

    sort(dragons.begin(), dragons.end());

    for(long long i = 0; i < n; i++)
    {
        if(s > dragons[i].first)
        {
            s += dragons[i].second;
        }
        else
        {
            cout << "NO";
            return 0;
        }
    }

    cout << "YES";

    return 0;
}
