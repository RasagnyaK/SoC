#include <iostream>
#include <vector>
using namespace std;

vector<vector<long long>> tree;
vector<long long> cat;
long long n, m;
long long ans = 0;

void dfs(long long node, long long parent, long long cnt)
{
    if(cat[node] == 1)
        cnt++;
    else
        cnt = 0;

    if(cnt > m)
        return;

    bool leaf = true;

    for(long long child : tree[node])
    {
        if(child != parent)
        {
            leaf = false;
            dfs(child, node, cnt);
        }
    }

    if(leaf)
        ans++;
}

int main()
{
    cin >> n >> m;

    cat.resize(n + 1);

    for(long long i = 1; i <= n; i++)
    {
        cin >> cat[i];
    }

    tree.resize(n + 1);

    for(long long i = 0; i < n - 1; i++)
    {
        long long u, v;
        cin >> u >> v;

        tree[u].push_back(v);
        tree[v].push_back(u);
    }

    dfs(1, 0, 0);

    cout << ans << "\n";

    return 0;
}
