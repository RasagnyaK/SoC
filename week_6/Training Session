#include <bits/stdc++.h>
using namespace std;

using ll = long long;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;

    while (t--) {
        int n;
        cin >> n;

        vector<pair<int,int>> problems(n);
        vector<ll> topic(n + 1, 0), diff(n + 1, 0);

        for (int i = 0; i < n; i++) {
            cin >> problems[i].first >> problems[i].second;
            topic[problems[i].first]++;
            diff[problems[i].second]++;
        }

        ll ans = 1LL * n * (n - 1) * (n - 2) / 6;

        for (auto [a, b] : problems) {
            ans -= (topic[a] - 1) * (diff[b] - 1);
        }

        cout << ans << '\n';
    }

    return 0;
}
