#include <iostream>
#include <vector>
#include <string>
using namespace std;

vector<vector<long long>> tree;
string s;
long long ans;

pair<long long, long long> dfs(long long node)
{
    long long white = 0;
    long long black = 0;

    // Visit all children
    for (long long child : tree[node])
    {
        pair<long long, long long> temp = dfs(child);

        white += temp.first;
        black += temp.second;
    }

    // Count the current node
    if (s[node - 1] == 'W')
        white++;
    else
        black++;

    // Check if subtree is balanced
    if (white == black)
        ans++;

    // Return white and black counts
    return {white, black};
}

int main()
{
    long long t;
    cin >> t;

    vector<long long> a(t);

    for (long long i = 0; i < t; i++)
    {
        cin >> a[i];

        vector<long long> b(a[i] - 1);

        // Create tree for this test case
        tree.assign(a[i] + 1, {});

        // Read parents
        for (long long j = 0; j < a[i] - 1; j++)
        {
            cin >> b[j];

            // Build adjacency list
            tree[b[j]].push_back(j + 2);
        }

        cin >> s;

        ans = 0;

        dfs(1);

        cout << ans << endl;
    }

    return 0;
}
