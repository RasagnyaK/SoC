#include <iostream>
#include <vector>
using namespace std;
int main(){
    long long n;
    cin >> n;
    int mx=0;
    vector<long long> freq(100001, 0);
    for(int i=0;i<n;i++){
        int x;
        cin >> x;
        freq[x]++;
        mx=max(mx,x);
    }
    vector<long long> points(100001);
    for(int i=1;i<=100000;i++){
        points[i] = 1LL * i * freq[i];
    }
    vector<long long> dp(mx + 1, 0);
    dp[0] = 0;
    dp[1] = points[1];
    for(int i = 2; i <= mx; i++){
        dp[i] = max(dp[i-1], dp[i-2] + points[i]);
    }
    cout << dp[mx] << "\n";
}
