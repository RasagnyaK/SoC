#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;
int main(){
    long long n;
    cin >> n;
    vector<long long> a(n);
    for(long long i=0;i<n;i++){
        cin >> a[i];
    }
    const int INF = 1e9;
    vector<vector<int>> dp(n+1, vector<int>(3, INF));

    dp[0][0] = 0;
    dp[0][1] = INF;
    dp[0][2] = INF;
    for(long long i=0;i<n;i++){
        if(a[i]==0){
            dp[i+1][0]=min({dp[i][0],dp[i][1],dp[i][2]})+1;
        }
        else if(a[i]==1){
            dp[i+1][0] = min({dp[i][0],dp[i][1],dp[i][2]})+1;
            dp[i+1][1]=min(dp[i][0],dp[i][2]);
        }
        else if(a[i]==2){
            dp[i+1][0] = min({dp[i][0],dp[i][1],dp[i][2]})+1;
            dp[i+1][2]=min(dp[i][0],dp[i][1]);
        }
        else if(a[i]==3){
            dp[i+1][0] = min({dp[i][0],dp[i][1],dp[i][2]})+1;
            dp[i+1][1]=min(dp[i][0],dp[i][2]);
            dp[i+1][2]=min(dp[i][0],dp[i][1]);
        }
    }
    int ans = min({dp[n][0], dp[n][1], dp[n][2]});
    cout << ans << "\n";
}
