#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;
int main(){
    long long t;
    cin >> t;
    for(long long i=0;i<t;i++){
        long long n;
        cin >> n;
        vector<long long> a(n);
        for(long long j=0;j<n;j++){
            cin >> a[j];
        }
        sort(a.begin(),a.end());
        cout << a[n-1]-a[0] << "\n";
    }
}
