#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;
int main(){
    long long n;
    cin >> n;
    vector<long long> a(n);
    for(long long i=0;i<n;i++){
        cin >> a[i];
    }
    vector<long long> b(n);
    for(long long i=0;i<n;i++){
        if(a[i]==0){
            b[i]=1;
        }
        else{
            b[i]=-1;
        }
    }
    long long best=-1e9;
    long long ones=0;
    for(long long i=0;i<n;i++){
        if(a[i]==1){
            ones+=1;
        }
    }
    for(long long i=0;i<n;i++){
        long long sum=0;
        for(long long j=i;j<n;j++){
            sum += b[j];
            best = max(best,sum);
        }
    }
    cout << best+ones << "\n";
}
