#include <iostream>
#include <vector>
#include <iomanip>
using namespace std;

vector<vector<long long>> adj;

double dfs(long long u, long long parent) {

    long long children = 0;
    double sum = 0;

    for (long long v : adj[u]) {

        if (v == parent) {
            continue;
        }

        children++;

        sum += 1.0 + dfs(v, u);
    }

    if (children == 0) {
        return 0;
    }

    return sum / children;
}

int main() {

    long long n;
    cin >> n;

    adj.resize(n + 1);

    for (long long i = 0; i < n - 1; i++) {

        long long u, v;
        cin >> u >> v;

        adj[u].push_back(v);
        adj[v].push_back(u);
    }

    cout << fixed << setprecision(10) << dfs(1, 0) << '\n';
}
