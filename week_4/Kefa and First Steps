#include <iostream>
#include <vector>
#include <string>
#include <algorithm>
#include <cctype>
using namespace std;
int main(){
    long long n;
    cin >> n;
    vector<long long> a(n);
    for(long long i=0;i<n;i++){
        cin >> a[i];
    }
    long long ans = 1;
    long long b = 1;
    for(long long i=0;i<n-1;i++){
        if(a[i]<=a[i+1]){
            b+=1;
        }
        else{
            ans = max(ans,b);
            b = 1;
        }
    }
    cout << max(ans,b) <<"\n";
}
