#include <iostream>
#include <string>
#include <vector>
using namespace std;
string jumble(string a){
    string s(a.length(), ' ');
    for(long long i=0;i<a.length();i++){
        s[i] = a[a.length()-1-i];
    }
    return s;
}
int main(){
    long long n;
    cin >> n;
    vector<long long> c(n);
    for(long long i=0;i<n;i++){
        cin >> c[i];
    }
    vector<string> s(n);
    for(long long i=0;i<n;i++){
        cin >> s[i];
    }
    vector<string> rev(n);
    for(long long i=0;i<n;i++){
        rev[i] = jumble(s[i]);
    }
    const long long INF = 1e18;
    vector<vector<long long>> dp(n, vector<long long>(2, INF));
    dp[0][0] = 0;
    dp[0][1] = c[0];
    for(long long i=1;i<n;i++){
        if(s[i-1]<=s[i]){
            dp[i][0] = min(dp[i][0], dp[i-1][0]);
        }
        if(rev[i-1]<=s[i]){
            dp[i][0] = min(dp[i][0], dp[i-1][1]);
        }
        if(s[i-1]<=rev[i]){
            dp[i][1] = min(dp[i][1], dp[i-1][0] + c[i]);
        }
        if(rev[i-1]<=rev[i]){
            dp[i][1] = min(dp[i][1], dp[i-1][1] + c[i]);
        }
    }
    if(min(dp[n-1][0], dp[n-1][1]) == INF){
        cout << "-1" << "\n";
    }
    else{
        cout << min(dp[n-1][0], dp[n-1][1]) << "\n";
    }
}
