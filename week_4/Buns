#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;
int main(){
    long long n,m,c,d;
    cin >> n >> m >> c >> d;
    long long dp[1001] = {};
    for(long long i=0;i<m;i++){
        long long p,q,r,s;
        cin >> p >> q >> r >> s;
        long long cnt;
        cnt = p/q;
        for(long long j=0;j<cnt;j++){
            for(long long k = n; k >= r; k--){
                dp[k] = max(dp[k], dp[k-r] + s);
            }
        }
    }
    for(long long j = c; j <= n; j++){
        dp[j] = max(dp[j], dp[j-c] + d);
    }
    cout << dp[n] << "\n";
}
